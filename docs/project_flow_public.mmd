flowchart TD
    A["原始书稿<br/>EPUB / PDF"] --> B["结构化抽取<br/>章节、段落、图片、公式"]
    B --> C["英文 Markdown 底稿"]
    B --> D["图片资源"]
    B --> E["抽取校验报告"]

    C --> F["术语库与翻译规范"]
    F --> G["分节机器翻译"]
    G --> H["初译基线"]
    G --> I["翻译状态与断点续跑"]

    H --> J["本地自动审计<br/>结构、数字、公式、图片、引用"]
    C --> J
    D --> J
    J --> K["审计报告"]
    J --> L["校订稿"]

    H --> M["重点章节语义审校"]
    C --> M
    M --> K
    K --> N["高可信修订筛选"]
    N --> L

    L --> O["站点内容生成"]
    D --> O
    F --> O
    O --> P["VitePress 文档站"]
    P --> Q["自动构建部署"]
    Q --> R["GitHub Pages 在线阅读"]

    S["后续优化<br/>审计精度、自动裁决、展示规范"] -.-> K
    S -.-> O

    classDef source fill:#eef6ff,stroke:#6aa3d8,color:#1d3557
    classDef artifact fill:#f7f7f7,stroke:#999,color:#333
    classDef review fill:#fff4e6,stroke:#d8953d,color:#5c3b00
    classDef publish fill:#ecf8ee,stroke:#4c9a5f,color:#174d27

    class A,C,D,E,H,I,K,L,P artifact
    class B,J,O source
    class G,M,N review
    class Q,R publish
